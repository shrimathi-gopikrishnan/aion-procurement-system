PORT=3001
NODE_ENV=development

# Database (SQLite - file-based, no install needed)
DB_PATH=./data/aion.db

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# Anthropic Claude API
GEMINI_API_KEY=key

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# CORS
FRONTEND_URL=http://localhost:3002
